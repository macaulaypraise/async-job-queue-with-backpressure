# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Redis (job queues + backpressure)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (job state persistence)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobqueue

# Backpressure watermarks
HIGH_WATERMARK=10000
LOW_WATERMARK=2000

# Worker settings
MAX_RETRIES=5
WORKER_COUNT=4


# Job execution timeout
JOB_TIMEOUT_SECONDS=30

# Priority queue weights (must sum to 100)
WEIGHT_CRITICAL=60
WEIGHT_HIGH=30
WEIGHT_NORMAL=10
